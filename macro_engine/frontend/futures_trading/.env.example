# ============================================================
# 期货智能交易系统 V6 — 环境变量配置
# ============================================================
#
# 使用方式：
#   复制本文件为 .env.local（不会被 git 提交）
#   或直接修改本文件后重启 npm run dev
#
# 开发环境默认值：VITE_USE_MOCK=true（使用 Mock 数据）
# 生产环境：VITE_USE_MOCK=false（连接真实后端）
#
# ============================================================

# ========== 数据源模式（必须）==========

# true  = 使用 Mock 模拟数据（开发/非交易时段）
# false = 连接真实后端 API（生产环境）
VITE_USE_MOCK=true

# ========== 后端地址（开发环境）==========
# 注意：这些变量当前在前端代码中未直接使用（baseURL 硬编码）。
# 后续统一 API Client 重构时会用到此变量。
VITE_API_BASE_URL=http://localhost:8000

# WebSocket 实时推送地址
VITE_WS_URL=ws://localhost:8000/ws/vnpy

# ========== 因子分析服务（端口 8001）==========
# IC 热力图、信号系统等因子数据
VITE_FACTOR_API_BASE_URL=http://localhost:8001

# ========== 构建模式（无需修改）==========
# 由 Vite 自动设置：development / production / test
# NODE_ENV=development
